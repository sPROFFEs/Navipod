# =============================================================================
# .env template — Own domain + Let's Encrypt deployment
# =============================================================================
#
# Copy to `.env` next to docker-compose.yaml and fill in placeholders.
#
# Pre-requisites BEFORE bringing up:
#   1. DNS A record for $DOMAIN → public IP of this host.
#   2. Firewall: ports 80 AND 443 open to the world. Port 80 is
#      required for the ACME HTTP-01 challenge.
#   3. Initial cert acquisition — see this template's README.md.
# =============================================================================

# --- Navipod Security ---
SECRET_KEY=generate_a_very_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Domain ---
# The public hostname Let's Encrypt issues a cert for and that nginx
# serves. MUST match the DNS A record.
DOMAIN=music.example.com
ALLOWED_HOSTS=music.example.com

# --- Let's Encrypt notification email ---
# Used for expiry warnings if a renewal ever fails. Use a real
# address you actually read.
ACME_EMAIL=you@example.com

# --- HTTPS is real here, keep secure cookies. ---
COOKIE_SECURE=true

# --- Storage / data root on the host ---------------------------------------
HOST_DATA_ROOT=/opt/saas-data
DATABASE_URL=
NAVIDROME_IMAGE=deluan/navidrome:latest

# --- Reaper / maintenance ---
CHECK_INTERVAL_MINUTES=30
IDLE_THRESHOLD_MINUTES=30
CONCURRENT_DOWNLOADS=3
POOL_STATUS_CACHE_TTL_SECONDS=60

# --- Backup ---
BACKUP_ROOT=/saas-data/backups
APP_SOURCE_ROOT=/workspace
COMPOSE_ENV_FILE=/saas-data/config/navipod.env
RUNTIME_ENV_FILE=/run/navipod/.env
BACKUP_SCHEDULER_POLL_SECONDS=60

# --- Updates ---
UPDATE_SOURCE_REPO_URL=https://github.com/sPROFFEs/Navipod
UPDATE_SOURCE_BRANCH=main
# Restart nginx and certbot on update too so a renewed cert ends up
# served by the new container without a manual reload.
UPDATE_MANAGED_SERVICES=concierge nginx certbot

# --- Reverse-proxy headers ---
# nginx in this mode IS our trusted reverse proxy, so concierge can
# trust X-Forwarded-* headers from it.
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_IPS=127.0.0.1,::1,172.20.0.0/16

# --- Image proxy limits ---
PROXY_IMAGE_MAX_BYTES=5242880
PROXY_IMAGE_TIMEOUT_SECONDS=8
PROXY_IMAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,image/avif

# --- Cloudflare Tunnel ---
# Not used in domain mode — keep the line so a future migration just
# means changing files, not editing env.
TUNNEL_TOKEN=unused-in-domain-mode
