# =============================================================================
# .env template — INTERNAL HTTP deployment (LAN / VPN)
# =============================================================================
#
# Copy to `.env` next to docker-compose.yaml and fill in the placeholders.
#
# WARNING: never expose this mode to the public internet. Cookies travel
# without TLS so any party on the network path can hijack a session.
# Keep it on a trusted network (Tailscale, WireGuard, home LAN).
# =============================================================================

# --- Navipod Security ---
SECRET_KEY=generate_a_very_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Network ---
# Use the LAN IP or hostname this Navipod is reachable at. `*` is a
# convenience wildcard — fine on a trusted private network, dangerous
# anywhere else.
DOMAIN=192.168.1.42
ALLOWED_HOSTS=*

# --- Cookies MUST be non-secure on plain HTTP. ---
# A `Secure` cookie is silently dropped by browsers on http:// origins
# and the login form will loop forever.
COOKIE_SECURE=false

# --- Storage / data root on the host ---------------------------------------
HOST_DATA_ROOT=/opt/saas-data
DATABASE_URL=
NAVIDROME_IMAGE=deluan/navidrome:latest

# --- Reaper / maintenance ---
CHECK_INTERVAL_MINUTES=30
IDLE_THRESHOLD_MINUTES=30
CONCURRENT_DOWNLOADS=3
POOL_STATUS_CACHE_TTL_SECONDS=60

# --- Backup ---
BACKUP_ROOT=/saas-data/backups
APP_SOURCE_ROOT=/workspace
COMPOSE_ENV_FILE=/saas-data/config/navipod.env
RUNTIME_ENV_FILE=/run/navipod/.env
BACKUP_SCHEDULER_POLL_SECONDS=60

# --- Updates ---
UPDATE_SOURCE_REPO_URL=https://github.com/sPROFFEs/Navipod
UPDATE_SOURCE_BRANCH=main
# `tunnel` is NOT in this list — it doesn't exist in the internal compose.
UPDATE_MANAGED_SERVICES=concierge nginx

# --- Reverse-proxy headers (we are NOT behind one in internal mode) ---
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=127.0.0.1,::1

# --- Image proxy limits ---
PROXY_IMAGE_MAX_BYTES=5242880
PROXY_IMAGE_TIMEOUT_SECONDS=8
PROXY_IMAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,image/avif

# --- Cloudflare Tunnel ---
# Not used in internal mode — the variable is kept here only so that a
# future migration to cloudflared mode just requires changing the file.
TUNNEL_TOKEN=unused-in-internal-mode
