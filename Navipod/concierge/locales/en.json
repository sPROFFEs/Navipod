    "help.title": "Setup Guide",
    "help.breadcrumb": "Docs",
    "help.subtitle": "Technical documentation for configuring Spotify, Last.fm, MusicBrainz, YouTube cookies, and Subsonic client connections.",
    "help.youtube.title": "YouTube Cookies",
    "help.youtube.desc": "Required to avoid \"Sign in to confirm you're not a robot\" error.",
    "help.youtube.step1": "Install Extension",
    "help.youtube.step1_desc": "Install the <span>\"Get cookies.txt LOCALLY\"</span> extension in Chrome or Firefox.",
    "help.youtube.step2": "Export",
    "help.youtube.step2_desc": "Log into YouTube with your account, open the extension and click \"Export\". A <code>cookies.txt</code> file will download.",
    "help.youtube.step3": "Upload to Server",
    "help.youtube.step3_desc": "Go to <a href=\"/settings/downloader\" class=\"text-link\">Settings > Engine</a> and upload the file.",
    "help.spotify.title": "Spotify API",
    "help.spotify.desc": "Enables high-quality metadata download and private Playlist reading.",
    "help.spotify.step1": "Developer Dashboard",
    "help.spotify.step1_desc": "Access <a href=\"https://developer.spotify.com/dashboard\" target=\"_blank\" class=\"text-link\">developer.spotify.com</a> and log in.",
    "help.spotify.step2": "Create App",
    "help.spotify.step2_desc": "Click \"Create App\". Name it (e.g., \"Navipod\"). In \"Redirect URI\" you can use <code>http://localhost/callback</code>.",
    "help.spotify.step3": "Get Credentials",
    "help.spotify.step3_desc": "Enter the created App, go to \"Settings\" and copy the <code>Client ID</code> and <code>Client Secret</code>.",
    "help.lastfm.title": "Last.fm API",
    "help.lastfm.desc": "Used for discovery, recommendations, metadata enrichment, and cover fallbacks.",
    "help.lastfm.step1": "Create an API Account",
    "help.lastfm.step1_desc": "Open <a href=\"https://www.last.fm/api/account/create\" target=\"_blank\" class=\"text-link\">last.fm/api/account/create</a> and register a new API application.",
    "help.lastfm.step2": "Copy the API Key",
    "help.lastfm.step2_desc": "Save the <code>API Key</code>. The <code>Shared Secret</code> is optional in Navipod and is only needed for signed Last.fm operations.",
    "help.lastfm.step3": "Save It in Navipod",
    "help.lastfm.step3_desc": "Go to <a href=\"/settings/downloader\" class=\"text-link\">Settings > Engine</a>, paste the key, and optionally add the shared secret.",
    "help.musicbrainz.title": "MusicBrainz",
    "help.musicbrainz.desc": "No API key is required. Navipod uses MusicBrainz for search, discovery, and metadata cross-matching.",
    "help.musicbrainz.step1": "No Credentials Needed",
    "help.musicbrainz.step1_desc": "MusicBrainz search works without a personal API key, so there is nothing to configure in user settings.",
    "help.musicbrainz.step2": "Use It in Search",
    "help.musicbrainz.step2_desc": "Open Search and enable the <code>MusicBrainz</code> source or include it in the global source mix.",
    "help.musicbrainz.step3": "Use Metadata Priority",
    "help.musicbrainz.step3_desc": "In <a href=\"/settings/downloader\" class=\"text-link\">Settings > Engine</a>, set your metadata provider priority so MusicBrainz can participate in cover and track matching fallbacks.",
