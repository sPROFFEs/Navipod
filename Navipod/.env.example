# --- Navipod Security ---
SECRET_KEY=generate_a_very_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Network Configuration ---
# Use your actual domain here. For local testing, use 'localhost'.
DOMAIN=domain.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,domain.com,*.domain.com

# --- Infrastructure ---
# Frequency of the reaper task (in minutes) to clean idle containers.
CHECK_INTERVAL_MINUTES=30
# How long a user container can stay idle before being stopped.
IDLE_THRESHOLD_MINUTES=30

# Advanced Settings
# Path on the HOST machine where data is stored (default: /opt/saas-data)
HOST_DATA_ROOT=/opt/saas-data
# Docker image for Navidrome (default: deluan/navidrome:latest)
NAVIDROME_IMAGE=deluan/navidrome:latest
# Max concurrent downloads per user
CONCURRENT_DOWNLOADS=3
# Backup storage path inside the concierge container
BACKUP_ROOT=/saas-data/backups
# Application source root inside the concierge container (used for git/build info and updates)
APP_SOURCE_ROOT=/workspace
# Compose env-file path used by the update manager and setup workflow
COMPOSE_ENV_FILE=/saas-data/config/navipod.env
# Mounted runtime env file path used for backup and restore
RUNTIME_ENV_FILE=/run/navipod/.env
# Scheduler polling interval for admin autobackup checks (seconds)
BACKUP_SCHEDULER_POLL_SECONDS=60
# Official update source checked by the app
UPDATE_SOURCE_REPO_URL=https://github.com/sPROFFEs/Navipod
UPDATE_SOURCE_BRANCH=main
# Services recreated by the updater after applying an update
UPDATE_MANAGED_SERVICES=concierge nginx tunnel
# Cookie security:
# - true: use secure cookies, required for public HTTPS deployments such as Cloudflare Tunnel
# - false: only for local plain HTTP testing
COOKIE_SECURE=true

# --- Cloudflare Tunnel ---
# Get this token from the Cloudflare Zero Trust Dashboard (optional).
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
